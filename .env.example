# ---------------------------------------------------------------------------
# nanobot cloud example environment
# ---------------------------------------------------------------------------
# Copy this file to .env and adjust values for your deployment.
#
# Cloud mode reads only variables prefixed with NANOBOT_CLOUD_.
# Platform-managed provider/model still come from the separate nanobot config
# file referenced by NANOBOT_CLOUD_NANOBOT_CONFIG_PATH.

# ---------------------------------------------------------------------------
# Core service
# ---------------------------------------------------------------------------

# Path to the platform-level nanobot config.json.
# This file controls the managed provider/model/tools defaults for cloud mode.
NANOBOT_CLOUD_NANOBOT_CONFIG_PATH=/absolute/path/to/platform-config.json

# Local cache directory used to mirror S3-backed user workspaces at runtime.
NANOBOT_CLOUD_LOCAL_CACHE_DIR=.nanobot-cloud

# FastAPI/uvicorn bind address and port.
NANOBOT_CLOUD_HOST=127.0.0.1
NANOBOT_CLOUD_PORT=8890

# Per-request timeout in seconds.
NANOBOT_CLOUD_REQUEST_TIMEOUT=120

# Object-store workspace prefix. User workspaces will live under:
#   ${NANOBOT_CLOUD_S3__PREFIX}/${NANOBOT_CLOUD_WORKSPACE_PREFIX}/{user_id}
NANOBOT_CLOUD_WORKSPACE_PREFIX=workspaces

# ---------------------------------------------------------------------------
# OAuth / OIDC access-token verification
# ---------------------------------------------------------------------------
# Configure EITHER:
# 1. shared secret verification (good for local/dev HS256 tokens), OR
# 2. JWKS URL verification (typical production OIDC setup).

# Token issuer (optional but recommended).
NANOBOT_CLOUD_AUTH__ISSUER=https://auth.example.com/

# Token audience expected by this API (optional, but recommended).
NANOBOT_CLOUD_AUTH__AUDIENCE=nanobot-cloud

# Claim used as the stable user id. Usually "sub".
NANOBOT_CLOUD_AUTH__USER_ID_CLAIM=sub

# Allowed JWT algorithms, JSON array string.
# Example for JWKS/OIDC:
# NANOBOT_CLOUD_AUTH__ALGORITHMS=["RS256"]
# Example for local HS256 testing:
# NANOBOT_CLOUD_AUTH__ALGORITHMS=["HS256"]
NANOBOT_CLOUD_AUTH__ALGORITHMS=["RS256"]

# Option A: JWKS-based verification
NANOBOT_CLOUD_AUTH__JWKS_URL=https://auth.example.com/.well-known/jwks.json

# Option B: shared-secret verification
# Leave empty in production JWKS mode.
NANOBOT_CLOUD_AUTH__SHARED_SECRET=

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
# Stateless multi-instance cloud mode uses Redis for:
# - online session state
# - distributed locks
# - short-lived idempotency / coordination state

NANOBOT_CLOUD_REDIS__URL=redis://127.0.0.1:6379/0
NANOBOT_CLOUD_REDIS__KEY_PREFIX=nanobot-cloud
NANOBOT_CLOUD_REDIS__SESSION_TTL_S=86400
NANOBOT_CLOUD_REDIS__LOCK_TTL_S=300

# ---------------------------------------------------------------------------
# S3-compatible object storage
# ---------------------------------------------------------------------------

# Bucket name for all cloud-mode data.
NANOBOT_CLOUD_S3__BUCKET=nanobot-cloud

# Optional top-level prefix inside the bucket.
NANOBOT_CLOUD_S3__PREFIX=

# S3-compatible endpoint.
# For MinIO, example: http://127.0.0.1:9000
NANOBOT_CLOUD_S3__ENDPOINT_URL=http://127.0.0.1:9000

# Region name if required by your provider.
NANOBOT_CLOUD_S3__REGION_NAME=us-east-1

# Access key / secret key for S3-compatible auth.
NANOBOT_CLOUD_S3__ACCESS_KEY_ID=minioadmin
NANOBOT_CLOUD_S3__SECRET_ACCESS_KEY=minioadmin
